{
  "name": "minecraft-agent-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Node/Mineflayer bot service: owns the game connection, exposes actions + events over WebSocket.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.2",
    "mineflayer": "^4.37.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  }
}
