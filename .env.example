# Minecraft: Esc -> Open to LAN -> Start LAN World.
# It prints "Local game hosted on port NNNNN" in chat. That port changes EVERY session.
MC_PORT=25565

# Optional. Leave blank to autodetect; set to your client version (e.g. 1.21.4) if the bot gets kicked.
MC_VERSION=

MC_USERNAME=agent

# Bot <-> brain websocket. Both sides read this.
WS_PORT=8080

# Brain
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
MAX_LLM_CALLS=50
